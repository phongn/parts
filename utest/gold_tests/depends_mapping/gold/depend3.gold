Verbose: [gtest] ["${PARTIDEXPORTS('part2a','*','foo',True)}", "${PARTIDEXPORTS('part2b','*','foo',True)}"] False
Verbose: [gtest] ["${PARTIDEXPORTS('part2a','*','foo_list',True)}", "${PARTIDEXPORTS('part2b','*','foo_list',True)}"] False
Verbose: [gtest] ${PARTIDEXPORTS('part2a','*','foo',True)} True
Verbose: [gtest] ${PARTIDEXPORTS('part2b','*','foo',True)} True
Verbose: [gtest] ${PARTIDEXPORTS('part2a','*','foo_list',True)} True
Verbose: [gtest] ${PARTIDEXPORTS('part2b','*','foo_list',True)} True
