Import('*')

env.PartName('a2_name')

print "part info"
print "PART_ALIAS",		env.subst('$PART_ALIAS'), env.subst('$PART_ALIAS')=='a_alias.a2_alias'
print "PART_ROOT_ALIAS",	env.subst('$PART_ROOT_ALIAS'), env.subst('$PART_ROOT_ALIAS')=='a_alias'
print "PART_PARENT_ALIAS",env.subst('$PART_PARENT_ALIAS'), env.subst('$PART_PARENT_ALIAS')=='a_alias'
print "PART_NAME",		env.subst('$PART_NAME'), env.subst('$PART_NAME')=='a_name.a2_name'
print "PART_ROOT_NAME",	env.subst('$PART_ROOT_NAME'), env.subst('$PART_ROOT_NAME')=='a_name'
print "PART_PARENT_NAME",env.subst('$PART_PARENT_NAME'), env.subst('$PART_PARENT_NAME')=='a_name'
print "PART_SHORT_NAME",	env.subst('$PART_SHORT_NAME'), env.subst('$PART_SHORT_NAME')=='a2_name'
print "PART_VERSION",		env.subst('$PART_VERSION'), env.subst('$PART_VERSION')=='1.0.0'
print "PART_SHORT_VERSION",env.subst('$PART_SHORT_VERSION'), env.subst('$PART_SHORT_VERSION')=='1.0'

