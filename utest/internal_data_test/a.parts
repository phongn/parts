
Import('*')

env.PartVersion('1.0.0')
env.PartName('a_name')

env.Part(alias='a1_alias', parts_file='a1.parts')
env.Part(alias='a2_alias', parts_file='a2.parts')

print "part info"
print "PART_ALIAS",		env.subst('$PART_ALIAS'), env.subst('$PART_ALIAS')=='a_alias'
print "PART_ROOT_ALIAS",	env.subst('$PART_ROOT_ALIAS'), env.subst('$PART_ROOT_ALIAS')=='a_alias'
print "PART_PARENT_ALIAS",env.subst('$PART_PARENT_ALIAS'), env.subst('$PART_PARENT_ALIAS')==''
print "PART_NAME",		env.subst('$PART_NAME'), env.subst('$PART_NAME')=='a_name'
print "PART_ROOT_NAME",	env.subst('$PART_ROOT_NAME'), env.subst('$PART_ROOT_NAME')=='a_name'
print "PART_PARENT_NAME",env.subst('$PART_PARENT_NAME'), env.subst('$PART_PARENT_NAME')==''
print "PART_SHORT_NAME",	env.subst('$PART_SHORT_NAME'), env.subst('$PART_SHORT_NAME')=='a_name'
print "PART_VERSION",		env.subst('$PART_VERSION'), env.subst('$PART_VERSION')=='1.0.0'
print "PART_SHORT_VERSION",env.subst('$PART_SHORT_VERSION'), env.subst('$PART_SHORT_VERSION')=='1.0'

env.DependsOn([Component('a.a1_name')])

