Import('*')

env.PartName('sub_a1_name')

env.Part(alias='suba1_alias', parts_file='suba/a1.parts')
env.Part(alias='suba2_alias', parts_file='suba/a2.parts')

print "part info"
print "PART_ALIAS",		env.subst('$PART_ALIAS'), env.subst('$PART_ALIAS')=='a_alias.a1_alias.sub_a1_alias'
print "PART_ROOT_ALIAS",	env.subst('$PART_ROOT_ALIAS'), env.subst('$PART_ROOT_ALIAS')=='a_alias'
print "PART_PARENT_ALIAS",env.subst('$PART_PARENT_ALIAS'), env.subst('$PART_PARENT_ALIAS')=='a_alias.a1_alias'
print "PART_NAME",		env.subst('$PART_NAME'), env.subst('$PART_NAME')=='a_name.a1_name.sub_a1_name'
print "PART_ROOT_NAME",	env.subst('$PART_ROOT_NAME'), env.subst('$PART_ROOT_NAME')=='a_name'
print "PART_PARENT_NAME",env.subst('$PART_PARENT_NAME'), env.subst('$PART_PARENT_NAME')=='a_name.a1_name'
print "PART_SHORT_NAME",	env.subst('$PART_SHORT_NAME'), env.subst('$PART_SHORT_NAME')=='sub_a1_name'
print "PART_VERSION",		env.subst('$PART_VERSION'), env.subst('$PART_VERSION')=='1.0.0'
print "PART_SHORT_VERSION",env.subst('$PART_SHORT_VERSION'), env.subst('$PART_SHORT_VERSION')=='1.0'


